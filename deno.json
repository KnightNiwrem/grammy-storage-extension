{
  "name": "@grammyjs/storage-extended",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "tasks": {
    "test": "deno test --allow-env --allow-import=lib.deno.dev,deno.land,jsr.io,cdn.skypack.dev",
    "check": "deno check --allow-import=lib.deno.dev,deno.land,jsr.io,cdn.skypack.dev src/mod.ts test/",
    "lint": "deno lint",
    "fmt_check": "deno fmt --check",
    "publish_dry": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "grammy": "npm:grammy@^1.42.0"
  },
  "fmt": {
    "exclude": [
      ".factory/",
      "draft-spec.md"
    ]
  }
}
